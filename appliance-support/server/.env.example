# Copy this file to `.env` and fill in your swaram.live API key.
# This is the ONLY secret the app needs.

SWARAM_API_KEY=swaram_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional — sensible defaults are used if you omit these.
# PORT=8090
# SWARAM_BASE_URL=https://api.swaram.live
# CORS_ORIGINS=http://localhost:5173
