# Copy this file to `.env` and fill in your swaram.live API key.
# SWARAM_API_KEY is the only real secret this app needs.

SWARAM_API_KEY=swaram_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Phone bridge (inbound Plivo calls) ---
# The PUBLIC host Plivo will reach this server on (your tunnel or server hostname).
# It is used to build the <Stream> wss:// URL in the answer XML. Set this whenever the
# server is behind a tunnel/proxy; if you omit it, the incoming request's Host is used.
PLIVO_PUBLIC_HOST=your-tunnel-or-host.example.com

# Optional — sensible defaults are used if you omit these.
# PORT=8090
# SWARAM_BASE_URL=https://api.swaram.live
# SWARAM_MODEL=mal-realtime-simple
# PLIVO_VOICE=mal-female        # agent "Anjana"  (use mal-male for "Anand")
# CORS_ORIGINS=http://localhost:5173

# NOTE: your Plivo Auth ID / Auth Token are NOT needed to RUN this app — they are only
# used once, in the Plivo console or REST API, to point your number's Application at
# this server's /api/plivo/answer URL. See the README ("Set up the phone number").
