# Copy this file to `.env` and fill in TWO keys.
# Unlike the other swaram demos, the tutor also calls Amazon Bedrock to turn an
# uploaded document into a study brief, so it needs a Bedrock key too.

# 1) Your swaram.live API key (for the realtime voice call).
SWARAM_API_KEY=swaram_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 2) Amazon Bedrock — a long-lived API key (bearer token). The AWS SDK reads
#    AWS_BEARER_TOKEN_BEDROCK automatically. Generate one in the AWS console:
#    Bedrock → API keys (or an IAM/bearer token with bedrock:InvokeModel).
AWS_BEARER_TOKEN_BEDROCK=ABSK_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AWS_REGION=us-west-2
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-6

# Optional — sensible defaults are used if you omit these.
# PORT=8090
# SWARAM_BASE_URL=https://api.swaram.live
# CORS_ORIGINS=http://localhost:5173
